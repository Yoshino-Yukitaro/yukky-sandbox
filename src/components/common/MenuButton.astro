---
import { Icon } from "astro-icon/components";
---

<span class="relative md:hidden ml-2 pr-4">
  <script>
    import "../../scripts/menu.js";
  </script>
  <button
    id="menu"
    aria-label="メニューを開く"
    aria-expanded="false"
    class="flex items-center justify-center w-10 h-10 rounded-full text-yellow-50 hover:bg-yellow-800 dark:hover:bg-slate-600 transition-colors duration-200"
  >
    <Icon id="menu-icon-open" name="lucide:menu" class="w-6 h-6" aria-hidden="true" />
    <Icon id="menu-icon-close" name="lucide:x" class="w-6 h-6 hidden" aria-hidden="true" />
  </button>
  <ul
    id="hidden_menu"
    class="text-base flex flex-col hidden absolute bg-yellow-50 dark:bg-slate-600 w-28 shadow-lg rounded-lg right-2 top-12 p-2 z-50"
  >
    <li class="rounded-md hover:bg-yellow-100 dark:hover:bg-slate-500 transition-colors duration-150">
      <a href="/" class="block px-3 py-2 text-yellow-900 dark:text-yellow-50">記事一覧</a>
    </li>
    <li class="rounded-md hover:bg-yellow-100 dark:hover:bg-slate-500 transition-colors duration-150">
      <a href="/introduction" class="block px-3 py-2 text-yellow-900 dark:text-yellow-50">自己紹介</a>
    </li>
  </ul>
</span>
