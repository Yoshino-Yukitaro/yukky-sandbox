---
interface Props {
  glaceonSrc: string;
  twitterSrc: string;
  githubSrc: string;
  qiitaSrc: string;
}
const { glaceonSrc, twitterSrc, githubSrc, qiitaSrc } = Astro.props;
---

<script define:vars={{ glaceonSrc, twitterSrc, githubSrc, qiitaSrc }}>
  function loadScript(src) {
    return new Promise((resolve, reject) => {
      const script = document.createElement('script');
      script.src = src;
      script.onload = resolve;
      script.onerror = reject;
      document.head.appendChild(script);
    });
  }

  function wrapText(ctx, text, maxWidth) {
    const lines = [];
    let line = '';
    for (const char of text) {
      const test = line + char;
      if (ctx.measureText(test).width > maxWidth && line) {
        lines.push(line);
        line = char;
      } else {
        line = test;
      }
    }
    if (line) lines.push(line);
    return lines;
  }

  // canvas にはアバター・名前・一言のみ描画（SNS は HTML オーバーレイで別管理）
  async function createProfileTexture(avatarUrl) {
    const W = 560, H = 300;
    const PAD = 24;
    const DIVIDER_X = 200;

    const canvas = document.createElement('canvas');
    canvas.width = W;
    canvas.height = H;
    const ctx = canvas.getContext('2d');

    // 背景
    const bg = ctx.createLinearGradient(0, 0, W, H);
    bg.addColorStop(0, '#FFFBEB');
    bg.addColorStop(1, '#FEF3C7');
    ctx.fillStyle = bg;
    const r = 24;
    ctx.beginPath();
    ctx.moveTo(r, 0); ctx.lineTo(W - r, 0);
    ctx.quadraticCurveTo(W, 0, W, r);
    ctx.lineTo(W, H - r);
    ctx.quadraticCurveTo(W, H, W - r, H);
    ctx.lineTo(r, H); ctx.quadraticCurveTo(0, H, 0, H - r);
    ctx.lineTo(0, r); ctx.quadraticCurveTo(0, 0, r, 0);
    ctx.fill();

    // 左カラム: アバター
    const avatarCx = DIVIDER_X / 2;
    const avatarCy = H / 2;
    const avatarR = 68;

    // グロー
    const glow = ctx.createRadialGradient(avatarCx, avatarCy, avatarR, avatarCx, avatarCy, avatarR + 18);
    glow.addColorStop(0, 'rgba(217,119,6,0.45)');
    glow.addColorStop(1, 'rgba(217,119,6,0)');
    ctx.fillStyle = glow;
    ctx.beginPath();
    ctx.arc(avatarCx, avatarCy, avatarR + 18, 0, Math.PI * 2);
    ctx.fill();

    // 枠リング
    ctx.beginPath();
    ctx.arc(avatarCx, avatarCy, avatarR + 5, 0, Math.PI * 2);
    ctx.fillStyle = '#D97706';
    ctx.fill();

    // アバター画像
    try {
      const img = new Image();
      await new Promise((res, rej) => { img.onload = res; img.onerror = rej; img.src = avatarUrl; });
      ctx.save();
      ctx.beginPath();
      ctx.arc(avatarCx, avatarCy, avatarR, 0, Math.PI * 2);
      ctx.clip();
      ctx.drawImage(img, avatarCx - avatarR, avatarCy - avatarR, avatarR * 2, avatarR * 2);
      ctx.restore();
    } catch {
      ctx.beginPath();
      ctx.arc(avatarCx, avatarCy, avatarR, 0, Math.PI * 2);
      ctx.fillStyle = '#FDE68A';
      ctx.fill();
    }

    // 縦区切り線（フェード）
    const divGrad = ctx.createLinearGradient(DIVIDER_X, PAD, DIVIDER_X, H - PAD);
    divGrad.addColorStop(0, 'rgba(217,119,6,0)');
    divGrad.addColorStop(0.25, '#D97706');
    divGrad.addColorStop(0.75, '#D97706');
    divGrad.addColorStop(1, 'rgba(217,119,6,0)');
    ctx.strokeStyle = divGrad;
    ctx.lineWidth = 1.5;
    ctx.beginPath();
    ctx.moveTo(DIVIDER_X, PAD);
    ctx.lineTo(DIVIDER_X, H - PAD);
    ctx.stroke();

    // 右カラム
    const RX = DIVIDER_X + PAD;
    const RW = W - RX - PAD;

    // 名前
    ctx.textAlign = 'left';
    ctx.textBaseline = 'middle';
    ctx.font = 'bold 54px sans-serif';
    ctx.fillStyle = '#92400E';
    ctx.fillText('ゆっきー', RX, H * 0.32);

    // 一言（折り返し）
    ctx.font = '22px sans-serif';
    ctx.fillStyle = '#6B7280';
    const lines = wrapText(ctx, 'ポケモンと旅行、美味しい料理が好きなエンジニアです。', RW);
    lines.forEach((line, i) => {
      ctx.fillText(line, RX, H * 0.58 + i * 32);
    });

    return canvas.toDataURL('image/png');
  }

  function buildSNSBar() {
    const bar = document.createElement('div');
    bar.id = 'ar-sns-bar';
    bar.style.cssText = [
      'display:none',
      'position:fixed',
      'bottom:24px',
      'left:50%',
      'transform:translateX(-50%)',
      'z-index:9999',
      'background:rgba(0,0,0,0.7)',
      'backdrop-filter:blur(8px)',
      'border:1px solid rgba(255,255,255,0.15)',
      'border-radius:20px',
      'padding:12px 20px',
      'gap:20px',
      'align-items:center',
    ].join(';');

    const links = [
      { href: 'https://twitter.com/Yu_yukk_Y',       src: twitterSrc, label: 'Twitter',  w: 56, h: 50 },
      { href: 'https://github.com/Yoshino-Yukitaro', src: githubSrc,  label: 'GitHub',   w: 56, h: 56 },
      { href: 'https://qiita.com/Yu_yukk_Y',         src: qiitaSrc,   label: 'Qiita',    w: 56, h: 56 },
    ];

    links.forEach(({ href, src, label, w, h }) => {
      const a = document.createElement('a');
      a.href = href;
      a.target = '_blank';
      a.rel = 'noopener noreferrer';
      a.style.cssText = 'display:flex;flex-direction:column;align-items:center;gap:4px;text-decoration:none;';

      const img = document.createElement('img');
      img.src = src;
      img.alt = label;
      img.width = w;
      img.height = h;
      img.style.cssText = 'object-fit:contain;transition:transform 0.15s;';
      img.addEventListener('touchstart', () => { img.style.transform = 'scale(1.15)'; });
      img.addEventListener('touchend',   () => { img.style.transform = 'scale(1)'; });

      const span = document.createElement('span');
      span.textContent = label;
      span.style.cssText = 'color:rgba(255,255,255,0.7);font-size:11px;';

      a.appendChild(img);
      a.appendChild(span);
      bar.appendChild(a);
    });

    return bar;
  }

  function stopAllCameraStreams() {
    document.querySelectorAll('video').forEach((v) => {
      if (v.srcObject) {
        v.srcObject.getTracks().forEach((t) => t.stop());
        v.srcObject = null;
      }
    });
  }

  function closeAR() {
    stopAllCameraStreams();
    const url = new URL(window.location.href);
    url.searchParams.delete('mode');
    window.location.href = url.toString();
  }

  function buildARShell() {
    document.body.innerHTML = `
      <div id="ar-ui-bar" style="position:fixed;top:0;left:0;right:0;z-index:9999;display:flex;justify-content:space-between;align-items:center;padding:12px 16px;background:rgba(0,0,0,0.6);">
        <span style="color:#FEF3C7;font-size:15px;font-weight:bold;letter-spacing:0.05em;">AR プロフィール</span>
        <button id="ar-close-btn" style="color:white;background:rgba(255,255,255,0.15);border:1px solid rgba(255,255,255,0.3);border-radius:50%;width:36px;height:36px;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;line-height:1;">✕</button>
      </div>
      <div id="ar-marker-hint" style="display:none;position:fixed;bottom:24px;left:50%;transform:translateX(-50%);z-index:9999;background:rgba(0,0,0,0.75);border:1px solid rgba(255,255,255,0.2);border-radius:16px;padding:16px 20px;text-align:center;color:white;min-width:240px;max-width:90vw;">
        <p style="font-size:13px;margin:0 0 10px;opacity:0.9;">ゆっきーマーカーをカメラにかざしてください</p>
        <img src="${glaceonSrc}" alt="ゆっきーARマーカー" style="width:88px;height:88px;margin:0 auto 8px;display:block;border:2px solid rgba(255,255,255,0.5);border-radius:6px;background:white;object-fit:contain;padding:4px;" />
        <p style="font-size:11px;opacity:0.6;margin:0;">自己紹介ページのアイコン画像がマーカーです</p>
      </div>
      <div id="ar-loading" style="position:fixed;inset:0;z-index:9998;display:flex;flex-direction:column;align-items:center;justify-content:center;background:#000;color:white;gap:16px;">
        <div style="width:48px;height:48px;border:4px solid rgba(255,255,255,0.3);border-top-color:white;border-radius:50%;animation:ar-spin 1s linear infinite;"></div>
        <p style="font-size:14px;opacity:0.8;margin:0;">AR を初期化中...</p>
      </div>
      <style>@keyframes ar-spin{to{transform:rotate(360deg)}}</style>
    `;
    document.body.style.cssText = 'overflow:hidden;margin:0;padding:0;background:#000;';

    // SNS バーをDOMに追加（初期は非表示）
    const snsBar = buildSNSBar();
    document.body.appendChild(snsBar);

    document.getElementById('ar-close-btn').addEventListener('click', closeAR);
  }

  async function initARMode() {
    buildARShell();

    try {
      const pattRes = await fetch('/pattern-glaceon.patt');
      if (!pattRes.ok) throw new Error('パターンファイルの読み込みに失敗しました');

      await loadScript('https://aframe.io/releases/1.5.0/aframe.min.js');
      await loadScript('https://raw.githack.com/AR-js-org/AR.js/3.4.5/aframe/build/aframe-ar.js');

      const textureUrl = await createProfileTexture(glaceonSrc);

      document.getElementById('ar-loading')?.remove();
      document.getElementById('ar-marker-hint').style.display = 'block';

      const scene = document.createElement('a-scene');
      scene.setAttribute('arjs', [
        'sourceType: webcam',
        'debugUIEnabled: false',
        'detectionMode: mono',
        'maxDetectionRate: 60',
        'canvasWidth: 640',
        'canvasHeight: 480',
      ].join('; '));
      scene.setAttribute('vr-mode-ui', 'enabled: false');
      scene.setAttribute('renderer', 'logarithmicDepthBuffer: true; precision: medium;');

      const assets = document.createElement('a-assets');
      const assetImg = document.createElement('img');
      assetImg.id = 'ar-profile-asset';
      assetImg.src = textureUrl;
      assets.appendChild(assetImg);
      scene.appendChild(assets);

      const marker = document.createElement('a-marker');
      marker.setAttribute('type', 'pattern');
      marker.setAttribute('url', '/pattern-glaceon.patt');
      marker.setAttribute('patternRatio', '0.5');
      marker.setAttribute('smooth', 'true');
      marker.setAttribute('smoothCount', '10');
      marker.setAttribute('smoothTolerance', '0.01');
      marker.setAttribute('smoothThreshold', '5');
      marker.id = 'ar-marker';

      const plane = document.createElement('a-plane');
      plane.setAttribute('src', '#ar-profile-asset');
      // canvas 560×300 → 約 16:9 ではなく 1.87:1
      plane.setAttribute('width', '3.2');
      plane.setAttribute('height', '1.71');
      plane.setAttribute('position', '0 0.01 0');
      plane.setAttribute('rotation', '-90 0 0');
      marker.appendChild(plane);
      scene.appendChild(marker);

      const camera = document.createElement('a-entity');
      camera.setAttribute('camera', '');
      scene.appendChild(camera);

      document.body.appendChild(scene);

      scene.addEventListener('loaded', () => {
        document.querySelectorAll('video').forEach((v) => { v.style.zIndex = '1'; });
        document.querySelectorAll('canvas').forEach((c) => { c.style.zIndex = '2'; });

        const markerEl = document.getElementById('ar-marker');
        const hint    = document.getElementById('ar-marker-hint');
        const snsBar  = document.getElementById('ar-sns-bar');

        if (markerEl) {
          markerEl.addEventListener('markerFound', () => {
            if (hint)   hint.style.display = 'none';
            if (snsBar) snsBar.style.display = 'flex';
          });
          markerEl.addEventListener('markerLost', () => {
            if (hint)   hint.style.display = 'block';
            if (snsBar) snsBar.style.display = 'none';
          });
        }
      });

    } catch (err) {
      const loading = document.getElementById('ar-loading');
      if (loading) {
        loading.innerHTML = `<p style="color:white;text-align:center;padding:20px;max-width:300px;">AR の読み込みに失敗しました。<br><br>${err instanceof Error ? err.message : 'カメラへのアクセスを許可してから再度お試しください。'}</p>`;
      }
    }
  }

  let arInitialized = false;

  document.addEventListener('DOMContentLoaded', () => {
    if (new URLSearchParams(window.location.search).get('mode') === 'ar') {
      arInitialized = true;
      initARMode();
    }
  });

  document.addEventListener('ar:launch', () => {
    if (arInitialized) return;
    arInitialized = true;
    initARMode();
  });
</script>
